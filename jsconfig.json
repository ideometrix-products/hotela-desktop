{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "module": "NodeNext",
        "target": "ESNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ESNext"
        ],
        "strict": false,
        "skipLibCheck": true,
        "checkJs": false
    },
    "typeAcquisition": {
        "include": [
            "node",
            "electron"
        ]
    },
    "exclude": [
        "node_modules",
        "build"
    ]
}